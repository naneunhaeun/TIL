arr = []
# 행 순회 (행을 기준으로 순회)
# y는 고정 x 순회
for y in range(4):
    for x in range(4):  
        arr[y][x]


# 열 순회 (열을 기준으로 순회)
# x고정, y는 순회
for x in range(4):
    for y in range(4):  
        arr[y][x] #--> 이건 고정 


# 2차원 리스트 입력하기
# -> 1차원 리스트를 입력하고 (4행을 4번 반복)

# 방법1) 리스트컴프리헨션
arr= [list(map(int, input().split())) for _ in range(4)] 

# 방법2) 빈리스트 만들고 append활용
arr = []
for _ in range(4):
    lst = list(map(int, input().split()))
    arr.append(lst)